{
  "name": "honey-skill",
  "version": "1.2.0",
  "description": "Honey (I Shrunk the AI) — write less code and say less about it. A coding skill that cuts agent token cost across every major AI coding tool.",
  "license": "MIT",
  "repository": "github:Green-PT/honey-for-devs",
  "homepage": "https://github.com/Green-PT/honey-for-devs",
  "bin": {
    "honey-install": "bin/install.js",
    "eso": "bin/eso.js",
    "eson": "bin/eso.js"
  },
  "scripts": {
    "bench:eso": "node bench/eso/run.mjs",
    "bench:formats": "node bench/eso/formats.mjs",
    "bench:ccr": "node bench/headroom/run.mjs",
    "bench:px": "node bench/px/run.mjs",
    "bench:ccr:comprehension": "node bench/headroom/comprehension.mjs",
    "bench:memory": "node bench/memory/run.mjs",
    "bench:all": "npm run bench:formats && npm run bench:ccr && npm run bench:ccr:comprehension",
    "build": "node scripts/build-rules.js && node scripts/build-openclaw-skills.js",
    "check": "node scripts/build-rules.js --check",
    "test": "node --test eso/*.test.js tests/*.test.js hooks/*.test.js && node scripts/build-rules.js --check"
  },
  "files": [
    "bin",
    "hooks",
    "eso",
    "scripts",
    "skills",
    "commands",
    ".claude-plugin",
    ".openclaw",
    "AGENTS.md"
  ],
  "devDependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@toon-format/toon": "^2.3.0",
    "gpt-tokenizer": "^3.4.0",
    "pxpipe-proxy": "^0.8.0"
  }
}
